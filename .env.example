# Copy to .env and adjust. NEVER commit .env.
# ---- Server ----
PORT=5180
HOST=127.0.0.1
NODE_ENV=development

# ---- Storage (kept outside git) ----
DATA_DIR=./data
DB_PATH=./data/portal.sqlite

# ---- Byte-identical reproduce test ----
# Absolute path to ONE staged town render dir from the separate Buses repo,
# e.g. a ".../St Ives/S5-render/v6.6_2026-07-10_1525" folder that contains
# gen_internal.js + its data + the shipped internal.svg / internal.jpg.
# The test is skipped if this is unset or missing.
FIXTURE_DIR=

# ---- Email (magic-link auth) ----
# Leave blank in dev: sign-in links are printed to the SERVER CONSOLE, not emailed.
EMAIL_PROVIDER=
EMAIL_FROM=

# ---- Demo seed (scripts/seed-demo.mjs) ----
# Where the separate Buses data repo lives, and who the admin user is.
BUSES_DIR=
ADMIN_EMAIL=peter@pcooper.me.uk
