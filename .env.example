# Copy to .env and adjust. NEVER commit .env.
# ---- Server ----
PORT=5180
HOST=127.0.0.1
NODE_ENV=development

# ---- Storage (kept outside git) ----
DATA_DIR=./data
DB_PATH=./data/portal.sqlite

# ---- Byte-identical reproduce test ----
# Absolute path to ONE staged town render dir from the separate Buses repo,
# e.g. a ".../St Ives/S5-render/v6.6_2026-07-10_1525" folder that contains
# gen_internal.js + its data + the shipped internal.svg / internal.jpg.
# The test is skipped if this is unset or missing.
FIXTURE_DIR=

# ---- Email (magic-link auth, later phases) ----
# Leave blank in dev: links are printed to the console instead of emailed.
EMAIL_PROVIDER=
EMAIL_FROM=
